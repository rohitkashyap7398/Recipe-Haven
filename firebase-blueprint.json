{
  "entities": {
    "Recipe": {
      "title": "Recipe",
      "description": "A food recipe profile.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Name of the dish." },
        "description": { "type": "string", "description": "Short summary of the recipe." },
        "image": { "type": "string", "format": "uri", "description": "URL to the recipe image." },
        "ingredients": { "type": "array", "description": "List of ingredients." },
        "instructions": { "type": "string", "description": "Step by step preparation guide." },
        "authorId": { "type": "string", "description": "ID of the user who created it." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "ingredients", "instructions", "authorId", "createdAt"]
    },
    "Chat": {
      "title": "Chat Message",
      "description": "A message in the community chat box.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The message content." },
        "userId": { "type": "string", "description": "The sender's UID." },
        "userName": { "type": "string", "description": "The sender's display name." },
        "userAvatar": { "type": "string", "format": "uri", "description": "URL to sender's photo." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "userId", "userName", "createdAt"]
    },
    "Favorite": {
      "title": "User Favorite",
      "description": "A mapping of user to their favorite recipe.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's UID." },
        "recipeId": { "type": "string", "description": "The recipe doc ID." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "recipeId", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's UID." },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "displayName", "phoneNumber", "createdAt"]
    }
  },
  "firestore": {
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Collection of available recipes."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Community chat messages."
    },
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User favorite mappings."
    },
    "/profiles/{profileId}": {
      "schema": "UserProfile",
      "description": "Extended user profiles."
    }
  }
}
