rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Recipes ---
    match /recipes/{recipeId} {
      function isValidRecipe(data) {
        return data.title is string && data.title.size() <= 100 &&
               data.description is string && data.description.size() <= 500 &&
               data.ingredients is list && data.ingredients.size() <= 50 &&
               data.instructions is string && data.instructions.size() <= 5000 &&
               data.authorId == request.auth.uid &&
               data.createdAt == request.time;
      }

      allow read: if true; // Publicly readable
      allow create: if isSignedIn() && isValidRecipe(incoming());
      allow update: if isOwner(existing().authorId) && isValidRecipe(incoming()) && 
                    incoming().createdAt == existing().createdAt; // author and created at are immutable
      allow delete: if isOwner(existing().authorId);
    }

    // --- Chats ---
    match /chats/{chatId} {
      function isValidChat(data) {
        return data.text is string && data.text.size() <= 280 &&
               data.userId == request.auth.uid &&
               data.userName is string && data.userName.size() <= 50 &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update, delete: if false; // Messages are immutable for community integrity
    }

    // --- Favorites ---
    match /favorites/{favoriteId} {
      function isValidFavorite(data) {
        return data.userId == request.auth.uid &&
               data.recipeId is string && data.recipeId.size() <= 128 &&
               data.createdAt == request.time;
      }

      allow read: if isOwner(resource.data.userId); // Only user can see their favorites
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Query enforcement
      allow create: if isSignedIn() && isValidFavorite(incoming());
      allow delete: if isOwner(existing().userId);
    }

    // --- Profiles ---
    match /profiles/{profileId} {
      function isValidProfile(data) {
        return data.userId == request.auth.uid &&
               data.displayName is string && data.displayName.size() >= 2 && data.displayName.size() <= 70 &&
               data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15 &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProfile(incoming());
      allow update: if isOwner(existing().userId) && isValidProfile(incoming()) &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if false;
    }
  }
}
